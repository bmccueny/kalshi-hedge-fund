# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Kalshi API (https://kalshi.com/sign-up → API Keys)
KALSHI_API_KEY=...
KALSHI_API_SECRET=...
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# News feeds
NEWS_API_KEY=...           # newsapi.org
POLYGON_API_KEY=...        # polygon.io for financial news

# Risk limits
MAX_POSITION_SIZE_USD=500
MAX_PORTFOLIO_HEAT_PCT=0.20    # max 20% of capital at risk
MAX_SINGLE_MARKET_PCT=0.05     # max 5% in any one market
DAILY_LOSS_LIMIT_USD=1000
TOTAL_CAPITAL_USD=10000

# DB
DB_PATH=./data/trading.db
