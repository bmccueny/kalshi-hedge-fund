# ── Kalshi API (required) ────────────────────────────────────────────────────
# Sign up at https://kalshi.com → Account → API Keys
# Generate an RSA keypair, upload the public key to Kalshi, save the private key
KALSHI_API_KEY=your-kalshi-api-key-uuid
KALSHI_RSA_KEY_PATH=./kalshi_rsa_key.pem
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# ── AI Providers ─────────────────────────────────────────────────────────────
# xAI Grok (required) — used for MarketScanner, news triage, portfolio monitor
# Get a key at https://console.x.ai
XAI_API_KEY=xai-...

# Anthropic (recommended) — used for ProbabilityAnalyst, RiskManager AI review
# Get a key at https://console.anthropic.com
# Falls back to Grok if not set, but Opus gives better probability estimates
ANTHROPIC_API_KEY=sk-ant-...

# ── News Feeds (optional) ───────────────────────────────────────────────────
NEWS_API_KEY=              # newsapi.org — free tier: 100 req/day
POLYGON_API_KEY=           # polygon.io — financial news supplement

# ── Risk Limits ──────────────────────────────────────────────────────────────
TOTAL_CAPITAL_USD=200
MAX_POSITION_SIZE_USD=100
MAX_PORTFOLIO_HEAT_PCT=0.20    # max 20% of capital at risk simultaneously
MAX_SINGLE_MARKET_PCT=0.05     # max 5% of capital in any one market
DAILY_LOSS_LIMIT_USD=50
MIN_EDGE_THRESHOLD=0.04        # minimum probability edge to trade (4%)

# ── Trading Mode ─────────────────────────────────────────────────────────────
DRY_RUN=true                   # true = log trades without placing them

# ── Scanner Settings ─────────────────────────────────────────────────────────
# Comma-separated categories to scan. Options:
#   All, Weather, Politics, Economics, Sports, Crypto, Tech,
#   Entertainment, Geopolitics, Science, Daily
SCAN_CATEGORIES=All

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/trading.db
